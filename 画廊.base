views:
  - type: cards
    name: 表格
    filters:
      or:
        - type == "anime"
        - type == "comic"
        - type == "novel"
        - type == "game"
    order:
      - file.name
      - rating
      - genre
      - author
    sort:
      - property: rating
        direction: DESC
    image: note.cover
    imageAspectRatio: 1.45
